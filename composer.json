{
    "name": "nodus-it/dev-tools",
    "description": "Einheitliche Dev-Befehle fuer Nodus-Projekte via Composer (d:* Docker, qa:* Lint/Analyse/Test) und bin/nd.",
    "type": "composer-plugin",
    "keywords": [
        "docker",
        "docker-compose",
        "phpstan",
        "pint",
        "composer-plugin",
        "developer-tools",
        "nodus-it"
    ],
    "homepage": "https://github.com/nodus-it/dev-tools",
    "license": "MIT",
    "authors": [
        {
            "name": "Bastian Schur",
            "email": "b.schur@nodus-it.de",
            "homepage": "https://www.nodus-it.de",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/nodus-it/dev-tools/issues",
        "source": "https://github.com/nodus-it/dev-tools"
    },
    "require": {
        "php": "^8.2",
        "composer-plugin-api": "^2.0",
        "laravel/pint": "^1.18",
        "phpstan/phpstan": "^2.1"
    },
    "require-dev": {
        "composer/composer": "^2.7"
    },
    "autoload": {
        "psr-4": {
            "Nodus\\DevTools\\": "src/"
        }
    },
    "bin": [
        "bin/nd"
    ],
    "extra": {
        "class": "Nodus\\DevTools\\Plugin",
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    }
}
